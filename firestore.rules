rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isVerifiedGGUser() {
      return request.auth != null;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isVerifiedGGUser() &&
        (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }
    function isSuperAdmin() {
      return isVerifiedGGUser() && getUserRole() == 'super_admin';
    }
    function ownsWeek(weekData) {
      return isVerifiedGGUser() && weekData.createdBy == request.auth.uid;
    }
    function ownsModule(moduleData) {
      return isVerifiedGGUser() && moduleData.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if request.auth != null && request.auth.uid == userId;
      allow write: if isSuperAdmin();
    }
    match /weeks/{weekId} {
      allow read: if true;
      allow create: if isVerifiedGGUser();
      allow update, delete: if isSuperAdmin() || ownsWeek(resource.data) || isAdmin();
      allow update: if isVerifiedGGUser() && resource.data.coLeaders.hasAny([request.auth.uid]);
    }
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if isVerifiedGGUser();
      allow delete: if isSuperAdmin();
      allow update: if false;
    }
    match /tallies/{tallyId} {
      allow create: if true;
      allow read: if isVerifiedGGUser();
      allow delete: if isSuperAdmin();
      allow update: if false;
    }
    match /surveyResponses/{responseId} {
      allow create: if true;
      allow read: if isVerifiedGGUser();
      allow delete: if isSuperAdmin();
      allow update: if false;
    }
    match /modules/{moduleId} {
      allow read: if resource.data.status == 'global';
      allow read: if isVerifiedGGUser() && ownsModule(resource.data);
      allow read: if isAdmin();
      allow create: if isVerifiedGGUser();
      allow update: if isVerifiedGGUser() && ownsModule(resource.data) && resource.data.status != 'global';
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
    match /organizations/{orgId} {
      allow read: if isVerifiedGGUser();
      allow write: if isSuperAdmin();
    }
    match /templates/{templateId} {
      allow read: if isVerifiedGGUser();
      allow create: if isVerifiedGGUser();
      allow update, delete: if isSuperAdmin() || resource.data.createdBy == request.auth.uid;
    }
  }
}
