rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() { return request.auth != null; }
    function isSuperAdmin() {
      return isAdmin() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }
    function ownsWeek(weekData) { return isAdmin() && weekData.createdBy == request.auth.uid; }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /weeks/{weekId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isSuperAdmin() || ownsWeek(resource.data);
    }

    match /contacts/{contactId} {
      allow create: if true;
      allow read: if isAdmin();
      allow delete: if isSuperAdmin();
      allow update: if false;
    }

    match /tallies/{tallyId} {
      allow create: if true;
      allow read: if isAdmin();
      allow delete: if isSuperAdmin();
      allow update: if false;
    }

    match /surveyResponses/{responseId} {
      allow create: if true;
      allow read: if isAdmin();
      allow delete: if isSuperAdmin();
      allow update: if false;
    }

    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /organizations/{orgId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
  }
}